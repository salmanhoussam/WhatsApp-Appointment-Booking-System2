# ──────────────────────────────────────────────────────────────
# Frontend Environment Variables — copy to .env and fill values
# Variables MUST start with VITE_ to be exposed to the browser
# ──────────────────────────────────────────────────────────────

# ── Backend API URL (Railway assigns this after backend deploy) ──
# No trailing slash. Example: https://my-backend.up.railway.app
VITE_API_URL=https://your-backend.up.railway.app

# Local development (already the default in publicApi.js if not set):
# VITE_API_URL=http://127.0.0.1:8000
